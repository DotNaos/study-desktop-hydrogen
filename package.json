{
  "name": "study-desktop-hydrogen",
"version": "1.0.3",
  "productName": "Study Desktop",
  "description": "Local Electron desktop app for Study Sync + Study Web",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ./node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node ./node_modules/electron-vite/bin/electron-vite.js build",
    "build:server": "npx esbuild src/main/server/headless.ts --bundle --platform=node --target=node20 --format=cjs --outfile=out/server/study-desktop-server.js --alias:@aryazos/ts-base/logging=./src/shared/logging.ts --alias:@aryazos/study/types=./src/shared/studyTypes.ts --external:puppeteer-core --external:@puppeteer/browsers --external:sqlite3 --external:electron",
    "start:server": "npm run build:server && node out/server/study-desktop-server.js",
    "preview": "node ./node_modules/electron-vite/bin/electron-vite.js preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "download:chromium": "node scripts/download-chromium.mjs",
    "build:mac": "npm run download:chromium && node ./node_modules/electron-vite/bin/electron-vite.js build && electron-builder --mac --arm64 --publish never",
    "build:win": "npm run download:chromium && node ./node_modules/electron-vite/bin/electron-vite.js build && electron-builder --win --x64",
    "build:linux": "node ./node_modules/electron-vite/bin/electron-vite.js build && electron-builder --linux",
    "install:mac": "npm run build:mac && open \"dist/$(ls dist | grep -E '\\.dmg$' | head -1)\""
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@heroui/react": "^3.0.0-beta.7",
    "@heroui/styles": "^3.0.0-beta.7",
    "@puppeteer/browsers": "^2.11.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.111.4",
    "@tanstack/react-router-devtools": "^1.157.11",
    "adm-zip": "^0.5.16",
    "ai": "^4.3.19",
    "animejs": "^4.3.5",
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "d3-hierarchy": "^3.1.2",
    "dotenv": "^16.4.7",
    "electron-store": "^8.2.0",
    "express": "^4.22.1",
    "lucide-react": "^0.563.0",
    "minimatch": "^10.1.1",
    "motion": "^12.29.2",
    "pdf-parse": "^1.1.1",
    "pino": "^10.1.0",
    "puppeteer-core": "^24.36.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-oidc-context": "^3.3.0",
    "remark-gfm": "^4.0.1",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/adm-zip": "^0.5.5",
    "@types/animejs": "^3.1.13",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.19",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/express": "^4.17.25",
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sqlite3": "^3.1.11",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^5.0.3",
    "electron": "39.2.4",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "esbuild": "^0.27.2",
    "pino-pretty": "^13.1.2",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.15"
  }
}
