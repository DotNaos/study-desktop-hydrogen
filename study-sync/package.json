{
  "name": "@aryazos/study-sync",
  "version": "1.0.0",
  "productName": "aryazos-study-sync",
  "description": "Aryazos Study Sync - Download pdf files and structure from Learning Platforms",
  "main": "./out/main/index.js",
  "bin": {
    "aryazos": "./out/cli/aryazos-cli.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:cli": "npx esbuild src/cli/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=out/cli/aryazos-cli.js --external:playwright --external:sqlite3 --external:electron --external:@google/generative-ai \"--external:@ai-sdk/*\" --external:ai",
    "install:cli": "bun run build:cli && bun install -g .",
    "build:server": "npx esbuild src/main/server/headless.ts --bundle --platform=node --target=node20 --format=cjs --outfile=out/server/aryazos-study-sync-server.js --external:playwright --external:sqlite3 --external:electron",
    "cli": "bun run build:cli && node out/cli/aryazos-cli.js",
    "start:server": "node out/server/aryazos-study-sync-server.js",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prep:desktop-packaging": "node scripts/prepare-packaging.mjs",
    "build:mac": "electron-vite build && bun run prep:desktop-packaging && electron-builder --mac",
    "build:win": "electron-vite build && bun run prep:desktop-packaging && electron-builder --win",
    "build:linux": "electron-vite build && bun run prep:desktop-packaging && electron-builder --linux",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "install:mac": "bun run build:mac && open \"dist/$(ls dist | grep -E '\\.dmg$' | grep $(uname -m | sed 's/x86_64/x64/' | sed 's/arm64/arm64/') | head -1)\"",
    "install:win": "bun run build:win && start dist\\*.exe",
    "install:linux": "bun run build:linux && xdg-open dist/*.AppImage"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@aryazos/study-cli": "workspace:*",
    "@aryazos/study-core": "workspace:*",
    "@aryazos/ts-base": "workspace:*",
    "@aryazos/ui": "workspace:*",
    "@aryazos/views": "workspace:*",
    "adm-zip": "^0.5.16",
    "ai": "^4.3.19",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.5",
    "electron-store": "^8.2.0",
    "express": "^4.22.1",
    "lucide-react": "^0.469.0",
    "minimatch": "^10.1.1",
    "pdf-parse": "^1.1.1",
    "pino": "^10.1.0",
    "playwright": "^1.55.0",
    "qrcode-terminal": "^0.11.0",
    "qrcode.react": "^4.2.0",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-resizable-panels": "^4.0.13",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/adm-zip": "^0.5.5",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/sqlite3": "^3.1.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^5.0.3",
    "electron": "39.2.4",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "esbuild": "^0.27.2",
    "pino-pretty": "^13.1.2",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.15"
  }
}
